{
    "dirs":{
        "page": "example/page",
        "inc": "example/inc"
    },
    "routes": {
        "/": ["inc@header.html", "page@welcome.html", "inc@footer.html"],
        "/auth/login": [
            "inc@header.html", "page@login-form.format", "inc@footer.html"],
        "/not-found": [
            "inc@header.html", "page@not-found.html", "inc@footer.html"],
        "/error": [
            "inc@header.html", "page@error.html", "inc@footer.html"]
    },
    "handlers": {
        "/auth/login": ["func@pw_auth", "action@redir"]
    },
    "knockouts": {
        "/auth/login": "get@/auth/login"
    },
    "banned-data": {"password": true},
    "port": 3000,
    "auth-socket": "example/auth.sock"
}
