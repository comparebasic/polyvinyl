{
    "dirs":{
        "page": "example/page",
        "inc": "example/inc",
        "static": "example/static",
        "user-data": "example/user-data",
        "auth-data": "example/auth-data",
        "sessions": "example/sessions",
        "emails": "example/emails"
    },
    "routes": {
        "/": [
            "get", "content=welcome.html@page"],
        "/auth/login": [
            ["get", "map=action/path@req", "set_query", "content=login-form.format@page", "end"],
            ["post", "map=email,send-email-auth?,password?@form", "set_query",
                ["data_eq=on@send-auth-email", "auth_email", "session_start", "redir=/auth/dashboard", "end"],
                ["pw_auth", "session_start", "redir=/auth/dashboard", "end"] 
            ],
            ["map=action/path@req", "content=login-form.format@page", "end"]
        ],
        "/auth/token-login": [
            ["get", "map=redir,token,email@query", "set_query", "token_consume", "session_start", "redir=redir@data", "end"],
            ["get", "content=token.format@page", "end"]
        ],
        "/auth/register": [
            ["get", "map=action/path@req", "map=redir@query", "set_query", "content=register.format@page", "end"],
            ["post", "map=action/path@req", "map=redir@query","set_query", "map=email,fullname,send-email-auth?,password?@form",
                ["data_eq=on@send-email-auth", "register", "get_token", "map=brand,url@config", "email=auth-token-email@emails",
                    "content=email-sent.format@page", "end"],
                ["data_neq=on@send-email-auth", "register", "pw_set", "redir=redir@data", "end"] 
            ],
            ["content=register.format@page", "end"]
        ],
        "/auth/dashboard": [
            ["get", "session_open", "map=email,fullname@session", "content=dashboard.format@page", "end"],
            ["set_query=redir/path@req", "redir=/auth/login", "end"]
        ],
        "/auth/logout": [
            ["get", "session_close", "redir=/", "end"],
            ["redir=/auth/login", "end"]
        ],
        "/static/styles.css": ["content=styles.css@static"],
        "/static/form.js": ["content=form.js@static"],
        "/not-found": ["content=not-found.html@page"],
        "/error": ["content=error.format@page"]
    },
    "templates": {
        "page": ["content=header.html@inc", true, "content=footer.html@inc"]
    },
    "fields": {
        "session": {
            "email-token": "unquote=email",
            "start-time": false,
            "session-token": true,
            "fullname": true
        },
        "user": {
            "fullname": true,
            "salt": false,
            "email-token": "unquote=email"
        },
        "auth": {
            "email-token": true,
            "password": false
        }
    },
    "port": 3000,
    "auth-socket": "example/auth.sock",
    "sasl-socket": "example/sasl.sock",
    "system-email": "noreply@cb-local",
    "brand": "Authdinger",
    "url": "http://localhost:3000",
    "smtp": "localhost"
}
