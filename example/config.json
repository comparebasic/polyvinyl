{
    "dirs":{
        "page": "example/page",
        "inc": "example/inc",
        "static": "example/static",
        "user-data": "example/user-data",
        "auth-data": "example/auth-data",
        "sessions": "example/sessions"
    },
    "routes": {
        "/": ["inc@header.html", "page@welcome.html", "inc@footer.html"],
        "/auth/login": [
            "inc@header.html", "page@login-form.format", "inc@footer.html"],
        "/auth/register": [
            "inc@header.html", "page@register.format", "inc@footer.html"],
        "/not-found": [
            "inc@header.html", "page@not-found.html", "inc@footer.html"],
        "/error": [
            "inc@header.html", "page@error.html", "inc@footer.html"],
        "/auth/dashboard": [
            "inc@header.html", "page@dashboard.format", "inc@footer.html"],
        "/static/styles.css": ["static@styles.css"]
    },
    "fields": {
        "session": {
            "email-token": false,
            "start-time": false,
            "session-token": true,
            "fullname": true
        },
        "user": {
            "fullname": true,
            "email": true
        }
    },
    "gathers": {
        "/user": ["func@gather_user"]
    },
    "handlers": {
        "/auth/login": ["func@pw_auth", "func@session_start", "action@redir"],
        "/auth/register": ["func@register", "func@pw_set", "action@redir"]
    },
    "knockouts": {
        "/auth/login": "get@/auth/login"
    },
    "banned-data": {"password": true},
    "port": 3000,
    "auth-socket": "example/auth.sock"
}
